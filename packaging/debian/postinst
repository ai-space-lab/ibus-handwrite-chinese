#!/bin/sh
set -e

MODEL_DIR="/usr/share/tegaki/models/zinnia"
LILY_DIR="/usr/local/share/ibus-handwrite-chinese/models"

mkdir -p "$LILY_DIR"

# Download 幽兰百合 model (best-effort, from Gitee)
if [ ! -f "$LILY_DIR/ZJHandWriting-zh_CN.model" ]; then
    echo "Downloading 幽兰百合 Community v1.1.0 model from Gitee..."
    if wget -q -O /tmp/lily.7z \
        https://gitee.com/LZQingXi/handwriting-zh_CN_Community/releases/download/v1.1.0/handwriting-zh_CN-community.7z; then
        7zr x -o"$LILY_DIR" /tmp/lily.7z 2>/dev/null || echo "Warning: 幽兰百合 extraction failed"
        rm -f /tmp/lily.7z
    else
        echo "Warning: 幽兰百合 download failed (Gitee unreachable). Install separately."
        rm -f /tmp/lily.7z
    fi
fi

# Reload udev rules
if command -v udevadm >/dev/null 2>&1; then
    udevadm control --reload-rules 2>/dev/null || true
    udevadm trigger 2>/dev/null || true
fi

exit 0
