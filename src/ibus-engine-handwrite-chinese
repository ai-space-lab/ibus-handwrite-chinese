        self.cand_bar.set_margin_top(4)
        self.cand_bar.set_margin_bottom(2)
        self.cand_bar.set_margin_start(6)
        self.cand_bar.set_margin_end(4)

        self.cand_inner = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=1)
        self.cand_bar.pack_start(self.cand_inner, True, True, 0)

