        self.drag_handle.connect("button-release-event", self.on_drag_end)
        self.drag_handle.connect("motion-notify-event", self.on_drag_move)
        self.drag_handle.connect("enter-notify-event", self.on_drag_enter)
        self.drag_handle.connect("leave-notify-event", self.on_drag_leave)
        top_bar = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=0)
        top_bar.pack_start(self.close_btn, False, False, 0)
        top_bar.pack_start(self.drag_handle, True, True, 0)
