class OnnxHandle:
    """PP-OCRv6 ONNX-based handwriting recognition backend."""

    def __init__(self, model_path, dict_path, max_candidates=MAX_CANDIDATES):
        if not HAS_NUMPY:
            raise RuntimeError("numpy is required for ONNX recognition")
        import onnxruntime
        self.session = onnxruntime.InferenceSession(
            model_path, providers=["CPUExecutionProvider"]
        )
        self.dict = []
        with open(dict_path, "r", encoding="utf-8") as f:
            for line in f:
                line = line.rstrip('\n')
                if line:
                    self.dict.append(line)
        # blank(0) + N chars + unknown(N+1)
        self.num_classes = len(self.dict) + 2
        self.max_candidates = max_candidates
        self.all_points = []
        self._last_results = []
        self._infer_lock = threading.Lock()
        self._log_session_id = str(uuid.uuid4())[:8]

    def _log(self, data):
        try:
            entry = {"session_id": self._log_session_id, "t": time.time(), **data}
            with open("/tmp/ppocr-recognition.log", "a") as f:
                f.write(json.dumps(entry, ensure_ascii=False) + "\n")
                f.flush()
        except Exception:
            pass

    def clear(self):
        self.all_points = []
        self._last_results = []

    def add_stroke(self, points):
        self.all_points.append(points)

    def _resize_bilinear(self, img, target_h):
        """Resize image to target_h height preserving aspect ratio."""
        h, w = img.shape
        scale = target_h / h
        target_w = max(int(w * scale), 1)
        src_y = np.arange(target_h, dtype=np.float32) * h / target_h
        src_x = np.arange(target_w, dtype=np.float32) * w / target_w
        y0 = np.floor(src_y).astype(np.int32)
        y1 = np.minimum(y0 + 1, h - 1)
        dy = src_y - y0
        x0 = np.floor(src_x).astype(np.int32)
        x1 = np.minimum(x0 + 1, w - 1)
        dx = src_x - x0
        return (
            img[y0[:, None], x0[None, :]] * (1 - dy[:, None]) * (1 - dx[None, :])
            + img[y1[:, None], x0[None, :]] * dy[:, None] * (1 - dx[None, :])
            + img[y0[:, None], x1[None, :]] * (1 - dy[:, None]) * dx[None, :]
            + img[y1[:, None], x1[None, :]] * dy[:, None] * dx[None, :]
        )

    def _preprocess(self):
        """Render strokes to numpy array and preprocess for ONNX inference."""
        if not self.all_points or not HAS_NUMPY:
            return None
        import cairo

        flat = [pt for stroke in self.all_points for pt in stroke]
        if not flat:
            return None
        xs = [p[0] for p in flat]
        ys = [p[1] for p in flat]
        xmin, xmax = min(xs), max(xs)
        ymin, ymax = min(ys), max(ys)
        # Canvas with padding, minimum 200px
        pad = 20
        cw = max(xmax - xmin + 2 * pad, 200)
        ch = max(ymax - ymin + 2 * pad, 200)
        width = int(cw)
        height = int(ch)
        # Render to ARGB32 offscreen surface
        surface = cairo.ImageSurface(cairo.FORMAT_ARGB32, width, height)
        cr = cairo.Context(surface)
        # White background
        cr.set_source_rgb(1, 1, 1)
        cr.paint()
        # Draw black strokes
        cr.set_source_rgb(0, 0, 0)
        cr.set_line_width(8)
        cr.set_line_cap(cairo.LINE_CAP_ROUND)
        cr.set_line_join(cairo.LINE_JOIN_ROUND)
        for stroke in self.all_points:
            if len(stroke) < 2:
                continue
            cr.move_to(
                stroke[0][0] - xmin + pad, stroke[0][1] - ymin + pad
            )
            for pt in stroke[1:]:
                cr.line_to(pt[0] - xmin + pad, pt[1] - ymin + pad)
            cr.stroke()
        # Extract R channel (ARGB32 little-endian: B,G,R,A)
        buf = surface.get_data()
        arr = np.frombuffer(buf, dtype=np.uint8).reshape(height, width, 4)
        gray = arr[:, :, 2].astype(np.float32)  # R channel
        # Resize to 48px height preserving aspect ratio
        resized = self._resize_bilinear(gray, 48)  # [48, W]
        # Normalize to [-1, 1]: pixel / 127.5 - 1.0
        normalized = resized / 127.5 - 1.0
        # Add batch & channel dims -> [1, 3, 48, W]
        normalized = normalized[np.newaxis, np.newaxis, :, :]  # [1, 1, 48, W]
        normalized = np.repeat(normalized, 3, axis=1)  # [1, 3, 48, W]
        try:
            self._log({
                "event": "preprocess",
                "num_strokes": len(self.all_points),
                "num_points": sum(len(s) for s in self.all_points),
                "canvas_size": [width, height],
                "resized_width": resized.shape[1],
                "img_min": round(float(normalized.min()), 4),
                "img_max": round(float(normalized.max()), 4),
                "img_mean": round(float(normalized.mean()), 4),
            })
        except Exception:
            pass
        return np.ascontiguousarray(normalized, dtype=np.float32)

    def _decode(self, output):
        """CTC decode via aggregation: average softmax across time, exclude blank."""
        probs = output[0]  # [T, num_classes]
        avg_probs = np.max(probs, axis=0)  # [num_classes] — max over time steps (CTC peak confidence)
        # Exclude blank (index 0) and unknown (last index)
        char_probs = avg_probs[1:-1]
        k = min(self.max_candidates, len(char_probs))
        top_indices = np.argpartition(char_probs, -k)[-k:]
        top_indices = top_indices[np.argsort(char_probs[top_indices])[::-1]]
        try:
            top5 = [(self.dict[idx], round(float(char_probs[idx]), 4)) for idx in top_indices[:5]]
            self._log({
                "event": "decode",
                "top5": top5,
                "num_classes": self.num_classes,
                "time_steps": int(output.shape[1]),
            })
        except Exception:
            pass
        return [(self.dict[idx], float(char_probs[idx])) for idx in top_indices]

    def classify(self):
        """Run inference synchronously, return [(char, score), ...]."""
        if not self.all_points or not HAS_NUMPY:
            return []
        t0 = time.time()
        input_tensor = self._preprocess()
        if input_tensor is None:
            self._log({"event": "classify", "latency_ms": 0, "input_shape": None})
            return []
        input_shape = list(input_tensor.shape)
        output = self.session.run(None, {"x": input_tensor})[0]
        result = self._decode(output)
        self._log({"event": "classify", "latency_ms": round((time.time() - t0) * 1000, 2), "input_shape": input_shape})
        return result

    def get_results(self):
        """Non-blocking get last results."""
        return list(self._last_results)

    def classify_async(self, callback):
        """Run inference in background thread, call callback via GLib.idle_add."""
        if not self._infer_lock.acquire(blocking=False):
            return  # inference already in progress

        def _run():
            try:
                results = self.classify()
                self._last_results = results
                GLib.idle_add(callback, results)
            finally:
                self._infer_lock.release()

        t = threading.Thread(target=_run, daemon=True)
        t.start()

    def destroy(self):
        self.all_points = []
        self._last_results = []


