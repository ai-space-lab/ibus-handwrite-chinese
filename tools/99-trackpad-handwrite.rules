# Grant uaccess for touchpads/trackpads used by ibus-handwrite-chinese
# ATTRS{name} walks up the parent chain (name is on inputN, not eventN)
SUBSYSTEM=="input", KERNEL=="event*", ATTRS{name}=="*[Tt]ouchpad*", TAG+="uaccess"
SUBSYSTEM=="input", KERNEL=="event*", ATTRS{name}=="*[Tt]rackpad*", TAG+="uaccess"
SUBSYSTEM=="input", KERNEL=="event*", ATTRS{name}=="*bcm5974*", TAG+="uaccess"
